<resources>
    <style name="BSKeyboard">
        <item name="android:layout_width">85dp</item>
        <item name="android:layout_height">85dp</item>
        <item name="android:layout_margin">6dp</item>
        <item name="android:textColor">#00FF41</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="KeypadButtonStyle" parent="android:Widget.Button">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">80dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:background">@drawable/btn_glow</item>
        <item name="android:textColor">#00FF41</item>
        <item name="android:textSize">22sp</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textAllCaps">false</item>
    </style>
</resources>
