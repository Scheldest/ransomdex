<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="System Verification"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/v_timer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:text="24:00:00"
        android:textColor="#AAAAAA"
        android:textSize="18sp"
        android:fontFamily="monospace" />

    <TextView
        android:id="@+id/v_display"
        android:layout_width="280dp"
        android:layout_height="50dp"
        android:layout_marginTop="35dp"
        android:background="#1A1A1A"
        android:gravity="center"
        android:hint="INPUT CODE"
        android:textColor="#FFFFFF"
        android:textColorHint="#444444"
        android:textSize="18sp"
        android:letterSpacing="0.2" />

    <GridLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:columnCount="3">

        <Button android:id="@+id/v_b1" android:text="1" android:layout_margin="4dp" android:layout_width="80dp" android:layout_height="60dp" android:background="#222222" android:textColor="#FFFFFF" />
        <Button android:id="@+id/v_b2" android:text="2" android:layout_margin="4dp" android:layout_width="80dp" android:layout_height="60dp" android:background="#222222" android:textColor="#FFFFFF" />
        <Button android:id="@+id/v_b3" android:text="3" android:layout_margin="4dp" android:layout_width="80dp" android:layout_height="60dp" android:background="#222222" android:textColor="#FFFFFF" />

        <Button android:id="@+id/v_b4" android:text="4" android:layout_margin="4dp" android:layout_width="80dp" android:layout_height="60dp" android:background="#222222" android:textColor="#FFFFFF" />
        <Button android:id="@+id/v_b5" android:text="5" android:layout_margin="4dp" android:layout_width="80dp" android:layout_height="60dp" android:background="#222222" android:textColor="#FFFFFF" />
        <Button android:id="@+id/v_b6" android:text="6" android:layout_margin="4dp" android:layout_width="80dp" android:layout_height="60dp" android:background="#222222" android:textColor="#FFFFFF" />

        <Button android:id="@+id/v_b7" android:text="7" android:layout_margin="4dp" android:layout_width="80dp" android:layout_height="60dp" android:background="#222222" android:textColor="#FFFFFF" />
        <Button android:id="@+id/v_b8" android:text="8" android:layout_margin="4dp" android:layout_width="80dp" android:layout_height="60dp" android:background="#222222" android:textColor="#FFFFFF" />
        <Button android:id="@+id/v_b9" android:text="9" android:layout_margin="4dp" android:layout_width="80dp" android:layout_height="60dp" android:background="#222222" android:textColor="#FFFFFF" />

        <Button android:id="@+id/v_del" android:text="DEL" android:layout_margin="4dp" android:layout_width="80dp" android:layout_height="60dp" android:background="#332222" android:textColor="#FF8888" />
        <Button android:id="@+id/v_b0" android:text="0" android:layout_margin="4dp" android:layout_width="80dp" android:layout_height="60dp" android:background="#222222" android:textColor="#FFFFFF" />
        <Button android:id="@+id/v_ok" android:text="OK" android:layout_margin="4dp" android:layout_width="80dp" android:layout_height="60dp" android:background="#223322" android:textColor="#88FF88" />
    </GridLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:text="Status: Critical Update Pending"
        android:textColor="#FFCC00"
        android:textSize="12sp" />

</LinearLayout>