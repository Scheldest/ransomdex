<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:gravity="bottom|center_horizontal"
    android:orientation="vertical"
    android:paddingBottom="50dp"
    android:paddingLeft="16dp"
    android:paddingRight="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="RansomDexAmbajut"
        android:textColor="#FF0000"
        android:textSize="42sp"
        android:textStyle="bold"
        android:shadowColor="#FF0000"
        android:shadowRadius="30" />

    <TextView
        android:id="@+id/textTimer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:text="24:00:00"
        android:textColor="#FF4444"
        android:textSize="30sp"
        android:textStyle="bold"
        android:fontFamily="monospace" />

    <TextView
        android:id="@+id/textDisplayPassword"
        android:layout_width="330dp" 
        android:layout_height="55dp"
        android:layout_marginTop="30dp"
        android:background="@drawable/input_glow"
        android:gravity="center"
        android:hint="ENTER KEY"
        android:textColor="#00FF41"
        android:textColorHint="#113311"
        android:textSize="26sp"
        android:letterSpacing="0.4" />

    <TextView
        android:id="@+id/textStatusMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="#FF4444"
        android:textSize="14sp"
        android:textStyle="bold" />

    <GridLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        android:columnCount="3">

        <Button android:id="@+id/btn1" android:text="1" android:layout_margin="2dp" android:layout_width="106dp" android:layout_height="80dp" android:background="@drawable/btn_glow" android:textColor="#00FF41" android:textSize="24sp" />
        <Button android:id="@+id/btn2" android:text="2" android:layout_margin="2dp" android:layout_width="106dp" android:layout_height="80dp" android:background="@drawable/btn_glow" android:textColor="#00FF41" android:textSize="24sp" />
        <Button android:id="@+id/btn3" android:text="3" android:layout_margin="2dp" android:layout_width="106dp" android:layout_height="80dp" android:background="@drawable/btn_glow" android:textColor="#00FF41" android:textSize="24sp" />
        
        <Button android:id="@+id/btn4" android:text="4" android:layout_margin="2dp" android:layout_width="106dp" android:layout_height="80dp" android:background="@drawable/btn_glow" android:textColor="#00FF41" android:textSize="24sp" />
        <Button android:id="@+id/btn5" android:text="5" android:layout_margin="2dp" android:layout_width="106dp" android:layout_height="80dp" android:background="@drawable/btn_glow" android:textColor="#00FF41" android:textSize="24sp" />
        <Button android:id="@+id/btn6" android:text="6" android:layout_margin="2dp" android:layout_width="106dp" android:layout_height="80dp" android:background="@drawable/btn_glow" android:textColor="#00FF41" android:textSize="24sp" />
        
        <Button android:id="@+id/btn7" android:text="7" android:layout_margin="2dp" android:layout_width="106dp" android:layout_height="80dp" android:background="@drawable/btn_glow" android:textColor="#00FF41" android:textSize="24sp" />
        <Button android:id="@+id/btn8" android:text="8" android:layout_margin="2dp" android:layout_width="106dp" android:layout_height="80dp" android:background="@drawable/btn_glow" android:textColor="#00FF41" android:textSize="24sp" />
        <Button android:id="@+id/btn9" android:text="9" android:layout_margin="2dp" android:layout_width="106dp" android:layout_height="80dp" android:background="@drawable/btn_glow" android:textColor="#00FF41" android:textSize="24sp" />
        
        <Button android:id="@+id/btnDelete" android:text="DEL" android:layout_margin="2dp" android:layout_width="106dp" android:layout_height="80dp" android:background="@drawable/btn_glow" android:textColor="#FF4444" android:textSize="18sp" />
        <Button android:id="@+id/btn0" android:text="0" android:layout_margin="2dp" android:layout_width="106dp" android:layout_height="80dp" android:background="@drawable/btn_glow" android:textColor="#00FF41" android:textSize="24sp" />
        <Button android:id="@+id/btnUnlock" android:text="OK" android:layout_margin="2dp" android:layout_width="106dp" android:layout_height="80dp" android:background="@drawable/btn_glow" android:textColor="#00FF41" android:textStyle="bold" android:textSize="20sp" />
    </GridLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FOR DECRYPTION KEY CONTACT:"
            android:textColor="#555555"
            android:textSize="11sp"
            android:letterSpacing="0.1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="+62 8XX-XXXX-XXXX" 
            android:textColor="#00FF41"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="monospace" />
    </LinearLayout>

</LinearLayout>