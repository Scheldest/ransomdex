<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SYSTEM ENCRYPTED"
        android:textColor="#00FF41"
        android:textSize="28sp"
        android:textStyle="bold"
        android:shadowColor="#00FF41"
        android:shadowDx="0"
        android:shadowDy="0"
        android:shadowRadius="15" />

    <View
        android:layout_width="200dp"
        android:layout_height="2dp"
        android:layout_marginTop="8dp"
        android:background="#00FF41" />

    <TextView
        android:id="@+id/textDisplayPassword"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_marginTop="40dp"
        android:background="#0A1A0A"
        android:gravity="center"
        android:hint="ENTER PIN"
        android:textColor="#00FF41"
        android:textColorHint="#113311"
        android:textSize="36sp"
        android:letterSpacing="0.2"
        android:shadowColor="#00FF41"
        android:shadowRadius="10" />

    <GridLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:columnCount="3"
        android:rowCount="4">

        <Button android:id="@+id/btn1" style="@style/HackerButton" android:text="1" />
        <Button android:id="@+id/btn2" style="@style/HackerButton" android:text="2" />
        <Button android:id="@+id/btn3" style="@style/HackerButton" android:text="3" />

        <Button android:id="@+id/btn4" style="@style/HackerButton" android:text="4" />
        <Button android:id="@+id/btn5" style="@style/HackerButton" android:text="5" />
        <Button android:id="@+id/btn6" style="@style/HackerButton" android:text="6" />

        <Button android:id="@+id/btn7" style="@style/HackerButton" android:text="7" />
        <Button android:id="@+id/btn8" style="@style/HackerButton" android:text="8" />
        <Button android:id="@+id/btn9" style="@style/HackerButton" android:text="9" />

        <Button android:id="@+id/btnDelete" style="@style/HackerButton" android:text="DEL" android:textColor="#FF4444" />
        <Button android:id="@+id/btn0" style="@style/HackerButton" android:text="0" />
        <Button android:id="@+id/btnUnlock" style="@style/HackerButton" android:text="OK" android:textColor="#00FF41" />

    </GridLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:text="UNAUTHORIZED ACCESS IS PROHIBITED"
        android:textColor="#333333"
        android:textSize="10sp" />

</LinearLayout>